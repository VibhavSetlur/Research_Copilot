# Research OS — environment variables
# Optional. Prefer setting these inside inputs/researcher_config.yaml so they
# travel with the project (and the server auto-injects them as env vars).
#
# This file is gitignored — never commit real keys.

# ── Literature / Search ────────────────────────────────────────────────
SEMANTIC_SCHOLAR_API_KEY=   # https://www.semanticscholar.org/product/api
S2_API_KEY=                 # alias — some SDKs read this name
NCBI_API_KEY=               # https://www.ncbi.nlm.nih.gov/account/ (PubMed)
CROSSREF_API_KEY=           # https://www.crossref.org
FIRECRAWL_API_KEY=          # https://firecrawl.io
SERPAPI_API_KEY=            # https://serpapi.com  (fallback web search)

# ── LLM providers (only if your IDE doesn't manage these) ──────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Runtime ────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
