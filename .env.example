# Research OS — External Research API Keys
# Copy this file to .env and fill in the values below.

# ==========================================
# Required: External Research Tools
# ==========================================
# Get your Firecrawl API key from: https://www.firecrawl.dev/
FIRECRAWL_API_KEY=""

# Get your Semantic Scholar API key from: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=""

# Crossref doesn't strictly require an API key, but providing your email
# places you in their "Polite Pool" for better rate limits.
CROSSREF_API_KEY="mailto:your-email@example.com"

# Get your NCBI API key for PubMed from: https://account.ncbi.nlm.nih.gov/
NCBI_API_KEY=""

# ==========================================
# Optional: Fallback Web Search
# ==========================================
# Get your SerpAPI key from: https://serpapi.com/
SERPAPI_API_KEY=""

# ==========================================
# Optional: Database & System Settings
# ==========================================
ENVIRONMENT="development"
LOG_LEVEL="INFO"
