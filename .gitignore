# Research Copilot — Git Ignore Rules
# Pattern: ignore generated outputs, commit all system files

TODO.md

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# Virtual environments
.venv/
venv/
env/
environment/venv/

# Generated outputs (AI-created during research)
/reports/
/data/
/01_workspace/
/02_experiments/
/03_synthesis/
/00_inputs/


# User's analysis scripts (numbered, created by AI during pipeline)
/scripts/01_*.py
/scripts/02_*.py
/scripts/03_*.py
/scripts/04_*.py
/scripts/05_*.py
/scripts/06_*.py
/scripts/07_*.py
/scripts/08_*.py
/scripts/09_*.py
/scripts/10_*.py

# Task logs (temporary)
task_*.log
*.log

# Scratch directory (temporary work)
scratch/

# .research/ — system configuration (keep config.yaml, ignore cache)
.research/cache/
.research/state/
.research/workflow_dag.json
.research/workflow_dag.mermaid

# User data (keep directories, ignore contents)
inputs/data/raw/*
!inputs/data/raw/.gitkeep
inputs/context/*
!inputs/context/.gitkeep
!inputs/context/README.md
inputs/papers/*
!inputs/papers/.gitkeep
!inputs/papers/README.md

# Large files (never commit)
*.h5
*.hdf5
*.feather
*.parquet
*.sav
*.dta
*.sas7bdat
*.zip
*.tar.gz
*.rar

# OS files
.DS_Store
Thumbs.db
desktop.ini

# AI assistant caches
.aider*
.cursor*
.antigravitycli/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Jupyter
.ipynb_checkpoints/

# Environment files (user-specific)
.env
.env.local
