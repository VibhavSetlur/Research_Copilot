FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        git \
        build-essential \
        python3 \
        python3-venv \
        python3-pip \
        openjdk-17-jre-headless \
        r-base \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace
