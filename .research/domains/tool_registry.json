{
  "version": "0.1.0",
  "tools": [
    {
      "id": "GATK4",
      "category": "variant_calling",
      "language": "bash",
      "invocation": "gatk --help",
      "install_check": "gatk --version",
      "install_cmd": "conda install -c bioconda gatk4",
      "container": "genomics",
      "input_formats": ["BAM", "CRAM", "VCF"],
      "output_formats": ["VCF"],
      "citation": "Van der Auwera et al., Curr Protoc Bioinformatics 2013.",
      "assumption_checks": ["variant_calling"],
      "notes": "Java-based; typically run in container or conda env."
    },
    {
      "id": "BWA-MEM2",
      "category": "alignment",
      "language": "bash",
      "invocation": "bwa-mem2 mem ref.fa reads.fq",
      "install_check": "bwa-mem2 version",
      "install_cmd": "conda install -c bioconda bwa-mem2",
      "container": "genomics",
      "input_formats": ["FASTQ", "FASTQ_GZ"],
      "output_formats": ["SAM", "BAM"],
      "citation": "Vasimuddin et al., arXiv 2019.",
      "assumption_checks": ["alignment_qc"],
      "notes": "Requires indexed reference genome."
    },
    {
      "id": "STAR",
      "category": "alignment",
      "language": "bash",
      "invocation": "STAR --runThreadN 8 --genomeDir ref --readFilesIn R1.fq.gz R2.fq.gz",
      "install_check": "STAR --version",
      "install_cmd": "conda install -c bioconda star",
      "container": "genomics",
      "input_formats": ["FASTQ", "FASTQ_GZ"],
      "output_formats": ["BAM"],
      "citation": "Dobin et al., Bioinformatics 2013.",
      "assumption_checks": ["alignment_qc"],
      "notes": "Splice-aware aligner for RNA-seq."
    },
    {
      "id": "Salmon",
      "category": "quantification",
      "language": "bash",
      "invocation": "salmon quant -i index -l A -1 R1.fq.gz -2 R2.fq.gz -o quant",
      "install_check": "salmon --version",
      "install_cmd": "conda install -c bioconda salmon",
      "container": "genomics",
      "input_formats": ["FASTQ", "FASTQ_GZ"],
      "output_formats": ["quant.sf"],
      "citation": "Patro et al., Nat Methods 2017.",
      "assumption_checks": ["differential_expression_rna"],
      "notes": "Use with transcriptome index."
    },
